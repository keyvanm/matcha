TS_AUTHKEY=tskey-auth-...

GITEA__server__DOMAIN=matcha.your-tailnet.ts.net
GITEA__server__SSH_DOMAIN=matcha.your-tailnet.ts.net
GITEA__server__ROOT_URL=https://matcha.your-tailnet.ts.net/
GITEA__server__APP_NAME=Matcha

# Restic backup (comma-separated for multiple destinations)
# Examples:
#   /mnt/backup/matcha
#   s3:s3.amazonaws.com/my-bucket/matcha
#   /mnt/backup/matcha,s3:s3.amazonaws.com/my-bucket/matcha
RESTIC_REPOSITORY=/mnt/backup/matcha
RESTIC_PASSWORD=your-strong-encryption-password

# Required only for S3 destinations
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
